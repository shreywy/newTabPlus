{
  "name": "newtab-plus",
  "version": "2.0.0",
  "description": "A beautiful glassmorphism new tab with quick links and weather",
  "scripts": {
    "build": "node build.js && tailwindcss -i src/index.css -o dist/style.css --minify",
    "build:js": "node build.js",
    "build:css": "tailwindcss -i src/index.css -o dist/style.css",
    "watch": "concurrently \"node build.watch.js\" \"tailwindcss -i src/index.css -o dist/style.css --watch\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.462.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  }
}
